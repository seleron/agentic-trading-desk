# Hermes autonomous-loop host config — COPY to loop.env (gitignored) and fill in.
#
#   cp scripts/hermes/loop.env.example scripts/hermes/loop.env
#
# These values are host-/account-specific (delivery targets, chat ids) and must
# NOT be committed. The loop scripts source loop.env if present; setup-routines.sh
# requires HERMES_DELIVER.

# Where Hermes routines deliver their output. For Telegram this is
# "telegram:<chat_id>" (the numeric chat id of the chat the bot posts to).
HERMES_DELIVER=telegram:000000000

# Where PR-review results are sent. Defaults to HERMES_DELIVER if unset.
# PR_REVIEW_NOTIFY=telegram:000000000
